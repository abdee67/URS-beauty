import 'package:dartz/dartz.dart';
import 'package:urs_beauty/core/errors/failures.dart';
import 'package:urs_beauty/features/payments/data/models/payment_model.dart';

abstract class PaymentRemoteDataSource {
  Future<Either<Failures, PaymentModel>> createPayment(
    String bookingId,
    String paymentMethod,
    String currency,
    double amount,
  );
  Future<Either<Failures, PaymentModel>> getPayment(String paymentId);
  Future<Either<Failures, PaymentModel>> updatePayment(
    String paymentId,
    String bookingId,
    String paymentMethod,
    String currency,
    double amount,
  );
  Future<Either<Failures, PaymentModel>> confirmCardPayment(
    String transactionReference,
  );
  Future<Either<Failures, PaymentModel>> submitBankTransferPayment(
    String bookingId,
    String proofUrl,
    String reference,
  );
  Future<Either<Failures, PaymentModel>> verfiyBankTransferPayment(
    String paymentId,
    bool isVerified,
  );
  Future<Either<Failures, PaymentModel>> calculateRefund(
    String paymentId,
  );
  Future<Either<Failures, PaymentModel>> processRefundPayment(
    String paymentId,
  );
  Future<Either<Failures, PaymentModel>> calculateRescheduleCost(
    String bookingId,
    String newServiceId,
  );
  Future<Either<Failures, PaymentModel>> processReschedulePayment(
    String bookingId,
    DateTime newDateTime,
    String newServiceId,
  );

}